[Unit]
Description=IP Monitor Service
After=network.target

[Service]
Type=simple
User=ipmon
WorkingDirectory=/home/ipmon
Group=syslog
ExecStart=/home/ipmon/ip_monitor.py
Restart=on-failure
RestartSec=3
StandardOutput=null
StandardError=null
SyslogIdentifier=ip_monitor

[Install]
WantedBy=multi-user.target

